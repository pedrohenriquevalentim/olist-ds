{
  "name": "@pedrohenriquevalentim/olist-ds",
  "version": "1.0.62",
  "description": "Olist Design System — componentes React + tokens",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./variables.css": "./dist/variables.css"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pedrohenriquevalentim/olist-ds.git"
  },
  "scripts": {
    "validate:icons": "node scripts/validate-icon-migration.mjs",
    "sync:skill": "node scripts/sync-skill.mjs",
    "build:tokens": "node scripts/sync-tokens.mjs",
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:tokens && node scripts/generate-index.mjs && tsc && node scripts/copy-css.mjs && npm run sync:skill && npm run sync:skill-meta",
    "dev": "vite",
    "generate:tests": "node scripts/generate-tests.mjs --missing",
    "generate:tests:all": "node scripts/generate-tests.mjs --all",
    "generate:stories": "node scripts/generate-stories.mjs --missing",
    "generate:stories:all": "node scripts/generate-stories.mjs --all",
    "generate:icons": "node scripts/generate-icons.mjs",
    "generate:all": "node scripts/generate-tests.mjs --missing && node scripts/generate-stories.mjs --missing",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build",
    "pipeline": "npm run build:tokens && npm run generate:all && npm run lint && tsc --noEmit && npm run test:run && npm run build-storybook",
    "version:skill": "node scripts/version-skill.mjs",
    "ship": "npm run pipeline && npm run sync:skill && npm run sync:skill-meta && git add -A && git commit -m 'chore: release' && npm version patch && git push origin HEAD --tags",
    "mcp:figma": "figma-mcp",
    "watch:tokens": "style-dictionary build --watch",
    "sync:skill-meta": "node scripts/sync-skill-meta.mjs",
    "wiki": "node scripts/generate-wiki.mjs",
    "postrelease": "npm run wiki",
    "chromatic": "npx chromatic --project-token=$CHROMATIC_PROJECT_TOKEN"
  },
  "keywords": [],
  "author": "Pedro Valentim",
  "license": "UNLICENSED",
  "type": "module",
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@axe-core/react": "^4.11.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@google/generative-ai": "^0.24.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tokens-studio/sd-transforms": "^2.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "chromatic": "^17.2.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "figma-mcp": "^0.1.4",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "storybook": "^10.4.6",
    "style-dictionary": "^5.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.5",
    "vitest": "^4.1.2",
    "vitest-axe": "^0.1.0"
  }
}
