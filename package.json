{
  "name": "olist",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:tokens": "node config.mjs",
    "dev": "vite",
    "generate:tests": "node scripts/generate-tests.mjs --missing",
    "generate:tests:all": "node scripts/generate-tests.mjs --all",
    "generate:stories": "node scripts/generate-stories.mjs --missing",
    "generate:stories:all": "node scripts/generate-stories.mjs --all",
    "generate:all": "node scripts/generate-tests.mjs --missing && node scripts/generate-stories.mjs --missing",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint src/",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "pipeline": "npm run build:tokens && npm run generate:all && npm run test:run && npm run build-storybook",
    "mcp:figma": "figma-mcp",
    "watch:tokens": "style-dictionary build --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@chromatic-com/storybook": "^5.1.1",
    "@google/generative-ai": "^0.24.1",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tokens-studio/sd-transforms": "^2.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "figma-mcp": "^0.1.4",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "storybook": "^10.3.4",
    "style-dictionary": "^5.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.2",
    "vitest-axe": "^0.1.0"
  }
}
