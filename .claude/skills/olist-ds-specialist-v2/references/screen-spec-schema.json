{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "olist-screen-spec-v1",
  "title": "Olist Screen Spec",
  "description": "Schema para geração de telas no Figma via plugin. Gerado por Claude + olist-ds-specialist.",

  "_example": {
    "project": {
      "name": "Aprovação de Pedidos",
      "source": "SDD-2024-037",
      "generatedAt": "2026-06-03T14:30:00Z",
      "skillVersion": "2.2"
    },

    "settings": {
      "viewport": { "width": 1440, "height": 900 },
      "padding": { "top": 24, "right": 80, "bottom": 24, "left": 80 }
    },

    "screens": [
      {
        "id": "screen-1",
        "name": "Lista de pedidos",
        "description": "Tela principal com tabela de pedidos aguardando aprovação",
        "state": "default",
        "order": 1,

        "layout": {
          "direction": "vertical",
          "gap": 24,
          "children": [

            {
              "id": "header",
              "type": "text",
              "role": "Heading",
              "content": "Aprovação de Pedidos"
            },

            {
              "id": "metric-card",
              "type": "frame",
              "direction": "horizontal",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "role": "Body",
                  "content": "Tempo médio: 2h 15min",
                  "style": { "fontWeight": 700, "fontSize": 32 }
                },
                {
                  "type": "text",
                  "role": "Caption",
                  "content": "Meta: < 2h | Últimos 30 dias"
                }
              ]
            },

            {
              "id": "filters",
              "type": "frame",
              "direction": "horizontal",
              "gap": 16,
              "children": [
                {
                  "type": "component",
                  "component": "Input Search",
                  "variant": { "state": "enabled", "action": "button icon" },
                  "overrides": { "placeholder": "Buscar pedido ou cliente" },
                  "width": 320
                },
                {
                  "type": "component",
                  "component": "Input Select",
                  "variant": { "state": "enabled", "type": "single select" },
                  "overrides": { "label": "Status", "placeholder": "Todos" },
                  "width": 200
                },
                {
                  "type": "component",
                  "component": "Button",
                  "variant": { "type": "secondary", "state": "enabled", "no icon": "on" },
                  "overrides": { "label": "Filtrar" }
                }
              ]
            },

            {
              "id": "table",
              "type": "component",
              "component": "Data Table",
              "proposed": true,
              "proposalReason": "Componente de tabela de dados não encontrado no inventário",
              "proposedSpec": {
                "name": "Data Table",
                "description": "Tabela de dados com cabeçalho fixo, ordenação por coluna e seleção em lote via checkbox",
                "tokens": [
                  "color/gray/gray-200 (border entre linhas)",
                  "color/gray/gray-50 (fundo cabeçalho)",
                  "font/size/14px (conteúdo)",
                  "font/size/12px (cabeçalho)",
                  "font/weight/semibold (cabeçalho)"
                ],
                "suggestedVariants": {
                  "density": ["default", "compact"],
                  "selectable": ["on", "off"]
                },
                "columns": [
                  { "header": "Pedido", "width": 120 },
                  { "header": "Cliente", "width": 200 },
                  { "header": "Valor", "width": 120, "align": "right" },
                  { "header": "Data", "width": 120 },
                  { "header": "Status", "width": 120 },
                  { "header": "Ações", "width": 160 }
                ],
                "sampleRows": 5
              }
            },

            {
              "id": "actions",
              "type": "frame",
              "direction": "horizontal",
              "gap": 12,
              "justify": "end",
              "children": [
                {
                  "type": "component",
                  "component": "Button",
                  "variant": { "type": "tertiary", "state": "enabled", "no icon": "on" },
                  "overrides": { "label": "Rejeitar Selecionados" }
                },
                {
                  "type": "component",
                  "component": "Button",
                  "variant": { "type": "primary", "state": "enabled", "no icon": "on" },
                  "overrides": { "label": "Aprovar Selecionados" }
                }
              ]
            }
          ]
        }
      },

      {
        "id": "screen-2",
        "name": "Lista de pedidos — estado vazio",
        "description": "Quando não há pedidos para aprovação",
        "state": "empty",
        "order": 2,

        "layout": {
          "direction": "vertical",
          "gap": 24,
          "align": "center",
          "children": [
            {
              "type": "text",
              "role": "Heading",
              "content": "Aprovação de Pedidos"
            },
            {
              "id": "empty-state",
              "type": "frame",
              "direction": "vertical",
              "gap": 16,
              "align": "center",
              "padding": { "top": 80, "bottom": 80 },
              "children": [
                {
                  "type": "text",
                  "role": "Section Title",
                  "content": "Tudo em dia!"
                },
                {
                  "type": "text",
                  "role": "Body",
                  "content": "Não há pedidos aguardando aprovação no momento."
                },
                {
                  "type": "component",
                  "component": "Button",
                  "variant": { "type": "secondary", "state": "enabled", "no icon": "on" },
                  "overrides": { "label": "Voltar ao painel" }
                }
              ]
            }
          ]
        }
      }
    ],

    "flow": [
      {
        "from": "screen-1",
        "to": "screen-2",
        "trigger": "Após aprovar último pedido pendente"
      }
    ]
  },

  "type": "object",
  "required": ["project", "screens"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "description": "Nome do projeto/feature" },
        "source": { "type": "string", "description": "ID do SDD/PRD de origem" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "skillVersion": { "type": "string" }
      }
    },

    "settings": {
      "type": "object",
      "properties": {
        "viewport": {
          "type": "object",
          "properties": {
            "width": { "type": "integer", "default": 1440 },
            "height": { "type": "integer", "default": 900 }
          }
        },
        "padding": {
          "type": "object",
          "properties": {
            "top": { "type": "integer", "default": 24 },
            "right": { "type": "integer", "default": 80 },
            "bottom": { "type": "integer", "default": 24 },
            "left": { "type": "integer", "default": 80 }
          }
        }
      }
    },

    "screens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "layout"],
        "properties": {
          "id": { "type": "string", "description": "Identificador único da tela" },
          "name": { "type": "string", "description": "Nome da tela (vira nome da page no Figma)" },
          "description": { "type": "string" },
          "state": { 
            "type": "string", 
            "description": "Estado da tela: default, empty, loading, error, success",
            "enum": ["default", "empty", "loading", "error", "success"]
          },
          "order": { "type": "integer" },
          "layout": { "$ref": "#/$defs/layoutNode" }
        }
      }
    },

    "flow": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": { "type": "string", "description": "ID da tela de origem" },
          "to": { "type": "string", "description": "ID da tela de destino" },
          "trigger": { "type": "string", "description": "Ação que dispara a transição" }
        }
      }
    }
  },

  "$defs": {
    "layoutNode": {
      "type": "object",
      "required": ["children"],
      "description": "Nó de layout — pode ser frame, componente ou texto",
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["frame", "component", "text"],
          "description": "frame = Auto Layout container, component = instância do DS, text = texto puro"
        },

        "direction": { "type": "string", "enum": ["vertical", "horizontal"] },
        "gap": { "type": "integer" },
        "padding": {
          "type": "object",
          "properties": {
            "top": { "type": "integer" },
            "right": { "type": "integer" },
            "bottom": { "type": "integer" },
            "left": { "type": "integer" }
          }
        },
        "align": { "type": "string", "enum": ["start", "center", "end", "stretch"] },
        "justify": { "type": "string", "enum": ["start", "center", "end", "space-between"] },
        "width": { "type": "integer" },
        "height": { "type": "integer" },

        "component": {
          "type": "string",
          "description": "Nome do componente no component-registry.json"
        },
        "variant": {
          "type": "object",
          "description": "Variantes do componente (ex: { type: 'primary', state: 'enabled' })"
        },
        "overrides": {
          "type": "object",
          "description": "Textos e props a sobrescrever (ex: { label: 'Salvar' })"
        },

        "proposed": {
          "type": "boolean",
          "description": "true se componente NÃO existe no inventário e está sendo proposto"
        },
        "proposalReason": { "type": "string" },
        "proposedSpec": {
          "type": "object",
          "description": "Especificação do componente proposto, seguindo tokens/foundations",
          "properties": {
            "name": { "type": "string" },
            "description": { "type": "string" },
            "tokens": { "type": "array", "items": { "type": "string" } },
            "suggestedVariants": { "type": "object" }
          }
        },

        "role": {
          "type": "string",
          "description": "Papel de texto conforme GLOSSARIO_PAPEIS_TEXTO.md",
          "enum": ["Heading", "Subheading", "Section Title", "Body", "Label", "Helper", "Error", "Caption", "CTA Label", "Link"]
        },
        "content": { "type": "string", "description": "Conteúdo do texto" },
        "style": {
          "type": "object",
          "description": "Estilos opcionais (fontSize, fontWeight, color)",
          "properties": {
            "fontSize": { "type": "integer" },
            "fontWeight": { "type": "integer" },
            "color": { "type": "string" }
          }
        },

        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/layoutNode" }
        }
      }
    }
  }
}
