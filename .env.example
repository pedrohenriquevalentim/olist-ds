# Variáveis de ambiente necessárias para o pipeline de desenvolvimento

# Chave da API do Google Gemini — usada pelos geradores de testes e stories (generate-tests.mjs, generate-stories.mjs)
# Obter em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Token do projeto Chromatic — usado para publicar o Storybook visual
# Obter em: https://www.chromatic.com (Settings > Project > Token)
CHROMATIC_PROJECT_TOKEN=
